---
import Page from '@/layouts/Page.astro';
import SocialLinks from '@/components/SocialLinks.astro';
import { Image } from 'astro:assets';
import portrait from '@/assets/images/marcel-heidebrecht-portrait.jpeg';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Marcel Heidebrecht',
  url: 'https://marcel-heidebrecht.de',
  email: 'marcel@heidebrecht.de',
  jobTitle: 'Fullstack Engineer & DevOps Enthusiast',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Berlin',
    addressCountry: 'DE',
  },
  sameAs: [
    'https://github.com/marcel290820',
    'https://www.linkedin.com/in/marcel-heidebrecht-a52296212',
    'https://x.com/marcel290820',
  ],
  alumniOf: [
    { '@type': 'CollegeOrUniversity', name: 'Technische Universitat Berlin' },
  ],
  knowsAbout: [
    'Full-Stack Development',
    'DevOps',
    'Cloud Infrastructure',
    'Kubernetes',
    'Terraform',
    'TypeScript',
    'Python',
    'JVM Ecosystem',
  ],
};
---

<Page title="About" description="About Marcel Heidebrecht - Fullstack Engineer and DevOps Enthusiast based in Berlin">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <h1 class="text-3xl sm:text-4xl font-bold tracking-tight mb-2">About me</h1>
  <p class="font-mono text-sm text-text-dim mb-8">whoami &amp; what i do</p>

  <div class="flex flex-col sm:flex-row items-start gap-8 mb-12">
    <div class="flex-1 prose prose-invert max-w-none">
      <p>I'm a fullstack engineer and DevOps enthusiast based in Berlin, currently pursuing my M.Sc. in Industrial Engineering & IT at TU Berlin while working as a DevOps Engineer at Capgemini. I thrive at the intersection of software and infrastructure — whether that's migrating microservices to AWS EKS with Terraform, building AI-powered automation pipelines, or designing full-stack tooling from scratch. Before diving deep into tech, I spent six months sailing across the world's oceans, mentoring students and researching microplastic pollution. That experience shaped how I approach engineering: methodical under pressure, curious by default, and always looking at the bigger picture.</p>
    </div>
    <div class="shrink-0 portrait-ring">
      <Image
        src={portrait}
        alt="Marcel Heidebrecht"
        width={640}
        height={640}
        class="object-cover w-40 h-40 block relative z-0"
      />
    </div>
  </div>

  <section class="mb-12">
    <div class="section-heading">
      <h2 class="font-mono text-sm font-medium text-text-muted">experience</h2>
    </div>
    <div class="flex flex-col gap-6">
      <div class="rail">
        <h3 class="text-base font-semibold mb-1">DevOps Engineer (Werkstudent)</h3>
        <p class="font-mono text-sm text-accent mb-1">Capgemini Deutschland GmbH</p>
        <p class="font-mono text-xs text-text-dim mb-2">Feb 2026 &mdash; present &middot; Berlin</p>
        <p class="text-sm text-text-muted">Cloud infrastructure automation and DevOps transformations in enterprise environments.</p>
      </div>

      <div class="rail">
        <h3 class="text-base font-semibold mb-1">Cloud, Data &amp; AI Consultant (Werkstudent)</h3>
        <p class="font-mono text-sm text-accent mb-1">Campana &amp; Schott GmbH</p>
        <p class="font-mono text-xs text-text-dim mb-2">Apr 2025 &mdash; Jan 2026 &middot; Berlin</p>
        <ul class="text-sm text-text-muted list-disc pl-4 space-y-1">
          <li>AI-powered lead generation agent with Python and browser automation</li>
          <li>Data platform maintenance for international clients; performance improvements</li>
          <li>Migration concept consolidating Azure Data Factory and Databricks into Microsoft Fabric</li>
          <li>Client project presentations and internal initiatives</li>
        </ul>
      </div>

      <div class="rail">
        <h3 class="text-base font-semibold mb-1">Software Engineer (Werkstudent)</h3>
        <p class="font-mono text-sm text-accent mb-1">Sourcepark GmbH</p>
        <p class="font-mono text-xs text-text-dim mb-2">Nov 2021 &mdash; Apr 2025 &middot; Berlin</p>
        <ul class="text-sm text-text-muted list-disc pl-4 space-y-1">
          <li>Cloud migration of a complex microservice system to AWS EKS; Terraform provisioning and Ansible configuration</li>
          <li>Java OCR app (Tesseract) and Playwright test project implementation</li>
          <li>Full-stack security scanner and custom Docker client tooling</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="mb-12">
    <div class="section-heading">
      <h2 class="font-mono text-sm font-medium text-text-muted">education</h2>
    </div>
    <div class="flex flex-col gap-6">
      <div class="rail">
        <h3 class="text-base font-semibold mb-1">M.Sc. Wirtschaftsingenieurwesen (IT)</h3>
        <p class="font-mono text-sm text-accent mb-1">Technische Universitat Berlin</p>
        <p class="font-mono text-xs text-text-dim mb-2">Oct 2023 &mdash; present</p>
        <p class="text-sm text-text-muted">Current GPA: 1.3 &middot; Focus: DevOps, Cloud Platforms, Distributed Systems</p>
      </div>
      <div class="rail">
        <h3 class="text-base font-semibold mb-1">B.Sc. Wirtschaftsingenieurwesen (IT)</h3>
        <p class="font-mono text-sm text-accent mb-1">Technische Universitat Berlin</p>
        <p class="font-mono text-xs text-text-dim mb-2">Oct 2019 &mdash; Sep 2023</p>
        <p class="text-sm text-text-muted">GPA: 1.3 (Top 3%) &middot; Focus: Software Engineering, Web Technologies, Project Management</p>
      </div>
    </div>
  </section>

  <section class="mb-12">
    <div class="section-heading">
      <h2 class="font-mono text-sm font-medium text-text-muted">skills</h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="chip">
        <h3 class="font-mono text-sm text-accent mb-2">full-stack</h3>
        <p class="text-sm text-text-muted">JVM ecosystem, TypeScript, Python, Vue, Astro, Spring, FastAPI, Rust, Solana</p>
      </div>
      <div class="chip">
        <h3 class="font-mono text-sm text-accent mb-2">devops</h3>
        <p class="text-sm text-text-muted">CI/CD systems, Terraform, Ansible, Git</p>
      </div>
      <div class="chip">
        <h3 class="font-mono text-sm text-accent mb-2">cloud</h3>
        <p class="text-sm text-text-muted">AWS, GCP, Azure, Kubernetes, Docker, Fabric, Databricks</p>
      </div>
      <div class="chip">
        <h3 class="font-mono text-sm text-accent mb-2">certs</h3>
        <p class="text-sm text-text-muted">ITILv4 Foundation, Azure Fundamentals AZ-900, Fabric Data Engineer DP-700</p>
      </div>
    </div>
  </section>

  <section class="mb-12">
    <div class="section-heading">
      <h2 class="font-mono text-sm font-medium text-text-muted">beyond code</h2>
    </div>
    <div class="flex flex-wrap gap-3">
      <span class="tag">Sailing</span>
      <span class="tag">Diving</span>
      <span class="tag">Gravel Biking</span>
      <span class="tag">Skiing</span>
      <span class="tag">Ocean Research</span>
    </div>
    <div class="mt-4 chip">
      <h3 class="font-mono text-sm text-accent mb-2">Ocean College &mdash; Global Sailing Expedition</h3>
      <p class="font-mono text-xs text-text-dim mb-2">Oct 2018 &mdash; Apr 2019</p>
      <p class="text-sm text-text-muted">Mentored 26 students during a 6-month global sailing expedition across 11 countries. Conducted scientific research on ocean microplastic pollution, published in FAZ.</p>
    </div>
  </section>

  <section class="mb-12">
    <div class="section-heading">
      <h2 class="font-mono text-sm font-medium text-text-muted">extracurricular</h2>
    </div>
    <div class="rail">
      <h3 class="text-base font-semibold mb-1">IT Department &mdash; Company Consulting Team</h3>
      <p class="font-mono text-xs text-text-dim mb-2">Jun 2024 &mdash; present &middot; Berlin</p>
      <ul class="text-sm text-text-muted list-disc pl-4 space-y-1">
        <li>Project lead for database redesign achieving 10x performance improvement</li>
        <li>Project controlling for BCM conception; internal LLM infrastructure rollout</li>
        <li>Knowledge management system, Python Slack app, GitLab CI/CD pipelines</li>
      </ul>
    </div>
  </section>

  <section>
    <div class="section-heading">
      <h2 class="font-mono text-sm font-medium text-text-muted">connect</h2>
    </div>
    <SocialLinks />
  </section>
</Page>
